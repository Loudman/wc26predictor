# Server
PORT=3001

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here

# JWT secret (any long random string)
JWT_SECRET=generate_with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# football-data.org API key — https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# Turso database (SQLite in the cloud) — https://turso.tech
# Local dev: leave as file:./wc26.db (no Turso account needed)
# Production (Vercel): set to your Turso database URL
TURSO_DATABASE_URL=file:./wc26.db
TURSO_AUTH_TOKEN=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
